{% import "_includes/forms" as forms %}

{% macro sortHeading(report, key, label) %}
    {% set active = report.sort == key %}
    <a href="{{ report.sortUrls[key] }}" class="so-sort-link{{ active ? ' is-active' : '' }}">
        {{ label|t('storage-optimizer') }}
        {% if active %}
            <span class="so-sort-dir">{{ report.direction|upper }}</span>
        {% endif %}
    </a>
{% endmacro %}

{% import _self as reportUi %}

<style>
    .so-utility {
        max-width: 1320px;
    }

    .so-intro {
        max-width: 980px;
    }

    .so-toolbar {
        align-items: flex-end;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin: 24px 0;
    }

    .so-action-form {
        align-items: flex-end;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .so-field label {
        color: #596673;
        display: block;
        font-size: 12px;
        font-weight: 600;
        margin: 0 0 4px;
    }

    .so-field-small input {
        width: 74px;
    }

    .so-metrics {
        background: #dfe5ec;
        border: 1px solid #dfe5ec;
        border-radius: 4px;
        display: grid;
        gap: 1px;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        margin: 18px 0 24px;
        overflow: hidden;
    }

    .so-metric {
        background: #fff;
        min-height: 70px;
        padding: 12px 14px;
    }

    .so-metric-label {
        color: #596673;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0;
        text-transform: uppercase;
    }

    .so-metric-value {
        color: #1f2933;
        font-size: 16px;
        font-weight: 600;
        line-height: 1.25;
        margin-top: 6px;
    }

    .so-metric-subvalue {
        color: #596673;
        font-size: 12px;
        font-weight: 500;
        margin-top: 4px;
    }

    .so-section-header {
        align-items: baseline;
        display: flex;
        flex-wrap: wrap;
        gap: 8px 16px;
        justify-content: space-between;
        margin: 26px 0 12px;
    }

    .so-section-header h3 {
        margin: 0;
    }

    .so-report-meta {
        color: #596673;
        font-size: 12px;
    }

    .so-table-wrap {
        border: 1px solid #dfe5ec;
        border-radius: 4px;
        overflow-x: auto;
    }

    .so-report-table {
        margin: 0;
        min-width: 1060px;
    }

    .so-report-table th {
        white-space: nowrap;
    }

    .so-report-table td {
        vertical-align: top;
    }

    .so-filename {
        max-width: 440px;
        overflow-wrap: anywhere;
    }

    .so-number {
        text-align: right;
        white-space: nowrap;
    }

    .so-muted {
        color: #8f98a3;
    }

    .so-sort-link {
        color: inherit;
        text-decoration: none;
    }

    .so-sort-link:hover {
        text-decoration: underline;
    }

    .so-sort-dir {
        color: #8f98a3;
        font-size: 10px;
        font-weight: 700;
        margin-left: 4px;
    }

    .so-pagination {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: space-between;
        margin-top: 12px;
    }

    .so-pager-buttons,
    .so-page-size {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .so-page-size-label {
        color: #596673;
        font-size: 12px;
        font-weight: 600;
    }

    .so-pagination .btn.active {
        background: #596673;
        color: #fff;
    }
</style>

<div class="so-utility">
    <div class="readable so-intro">
        <h2>{{ "Asset Optimizer"|t('storage-optimizer') }}</h2>
        <p>{{ "Scans are queued and processed in batches. Ghost assets are assets with no Craft relation references; generated WebP assets are protected while their source GIF is still active."|t('storage-optimizer') }}</p>
    </div>

    <div class="so-toolbar">
        <form method="post" accept-charset="UTF-8" class="so-action-form">
            {{ csrfInput() }}
            {{ actionInput('storage-optimizer/asset-usage/scan') }}
            {{ redirectInput(craft.app.request.url) }}

            <div class="so-field">
                <label for="assetScanVolume">{{ "Volume"|t('storage-optimizer') }}</label>
                {{ forms.select({
                    id: 'assetScanVolume',
                    name: 'volumeId',
                    options: volumeOptions,
                }) }}
            </div>

            <div class="so-field so-field-small">
                <label for="assetScanBatchSize">{{ "Scan batch size"|t('storage-optimizer') }}</label>
                {{ forms.text({
                    id: 'assetScanBatchSize',
                    name: 'batchSize',
                    value: defaultBatchSize,
                    type: 'number',
                    min: 1,
                    max: 5000,
                    size: 5,
                }) }}
            </div>

            <button type="submit" class="btn submit">{{ "Start asset scan"|t('storage-optimizer') }}</button>
        </form>

        {% if latestRun %}
            <form method="post" accept-charset="UTF-8" class="so-action-form">
                {{ csrfInput() }}
                {{ actionInput('storage-optimizer/asset-usage/clear') }}
                {{ redirectInput(craft.app.request.url) }}
                <button type="submit" class="btn">{{ "Clear snapshots"|t('storage-optimizer') }}</button>
            </form>

            {% if latestRun.deleteIsActive %}
                {% set cancelGhostConfirm = "Cancel the active ghost asset deletion? The current batch may finish, but no new batches will be queued."|t('storage-optimizer') %}
                <form method="post" accept-charset="UTF-8" class="so-action-form" onsubmit="return confirm('{{ cancelGhostConfirm|e('js') }}');">
                    {{ csrfInput() }}
                    {{ actionInput('storage-optimizer/asset-usage/cancel-delete-ghosts') }}
                    {{ redirectInput(craft.app.request.url) }}
                    {{ hiddenInput('runId', latestRun.id) }}
                    <button type="submit" class="btn">{{ "Cancel deletion"|t('storage-optimizer') }}</button>
                </form>
            {% endif %}

            {% if latestRun.deleteCanQueue %}
                {% set deleteGhostConfirm = "Queue deletion of {count} ghost assets from this snapshot? Assets are re-checked before deletion and moved to Craft's trash."|t('storage-optimizer', { count: latestRun.ghostAssets }) %}
                <form method="post" accept-charset="UTF-8" class="so-action-form" onsubmit="return confirm('{{ deleteGhostConfirm|e('js') }}');">
                    {{ csrfInput() }}
                    {{ actionInput('storage-optimizer/asset-usage/delete-ghosts') }}
                    {{ redirectInput(craft.app.request.url) }}
                    {{ hiddenInput('runId', latestRun.id) }}

                    <div class="so-field so-field-small">
                        <label for="assetDeleteBatchSize">{{ "Delete batch size"|t('storage-optimizer') }}</label>
                        {{ forms.text({
                            id: 'assetDeleteBatchSize',
                            name: 'batchSize',
                            value: defaultDeleteBatchSize,
                            type: 'number',
                            min: 1,
                            max: 1000,
                            size: 5,
                        }) }}
                    </div>

                    <button type="submit" class="btn submit delete">{{ "Delete ghost assets"|t('storage-optimizer') }}</button>
                </form>
            {% endif %}
        {% endif %}
    </div>

    {% if not latestRun %}
        <p>{{ "No asset usage scan has been run yet."|t('storage-optimizer') }}</p>
    {% else %}
        {% set runVolume = latestRun.volumeName ?: (latestRun.volumeId ? '#' ~ latestRun.volumeId : 'All'|t('storage-optimizer')) %}

        <div class="so-metrics">
            <div class="so-metric">
                <div class="so-metric-label">{{ "Status"|t('storage-optimizer') }}</div>
                <div class="so-metric-value">{{ latestRun.status }}</div>
            </div>
            <div class="so-metric">
                <div class="so-metric-label">{{ "Volume"|t('storage-optimizer') }}</div>
                <div class="so-metric-value">{{ runVolume }}</div>
            </div>
            <div class="so-metric">
                <div class="so-metric-label">{{ "Assets"|t('storage-optimizer') }}</div>
                <div class="so-metric-value">{{ latestRun.assetCount|number }}</div>
            </div>
            <div class="so-metric">
                <div class="so-metric-label">{{ "Total size"|t('storage-optimizer') }}</div>
                <div class="so-metric-value">{{ latestRun.totalBytesFormatted }}</div>
            </div>
            <div class="so-metric">
                <div class="so-metric-label">{{ "Average size"|t('storage-optimizer') }}</div>
                <div class="so-metric-value">{{ latestRun.averageBytesFormatted }}</div>
            </div>
            <div class="so-metric">
                <div class="so-metric-label">{{ "Related assets"|t('storage-optimizer') }}</div>
                <div class="so-metric-value">{{ latestRun.relatedAssets|number }}</div>
            </div>
            <div class="so-metric">
                <div class="so-metric-label">{{ "Ghost assets"|t('storage-optimizer') }}</div>
                <div class="so-metric-value">{{ latestRun.ghostAssets|number }}</div>
            </div>
            <div class="so-metric">
                <div class="so-metric-label">{{ "Ghost size"|t('storage-optimizer') }}</div>
                <div class="so-metric-value">{{ latestRun.ghostBytesFormatted }}</div>
                <div class="so-metric-subvalue">{{ "{size} MB"|t('storage-optimizer', { size: latestRun.ghostBytesMegabytesFormatted }) }}</div>
            </div>
            <div class="so-metric">
                <div class="so-metric-label">{{ "Protected assets"|t('storage-optimizer') }}</div>
                <div class="so-metric-value">{{ latestRun.protectedAssets|number }}</div>
            </div>
            <div class="so-metric">
                <div class="so-metric-label">{{ "Relation references"|t('storage-optimizer') }}</div>
                <div class="so-metric-value">{{ latestRun.relationCount|number }}</div>
            </div>
            <div class="so-metric">
                <div class="so-metric-label">{{ "Matrix references"|t('storage-optimizer') }}</div>
                <div class="so-metric-value">{{ latestRun.matrixRelationCount|number }}</div>
            </div>
            <div class="so-metric">
                <div class="so-metric-label">{{ "Largest asset"|t('storage-optimizer') }}</div>
                <div class="so-metric-value">
                    {{ latestRun.largestBytesFormatted }}
                    {% if latestRun.largestAssetId %}<span class="so-muted">#{{ latestRun.largestAssetId }}</span>{% endif %}
                </div>
            </div>
        </div>

        {% if latestRun.lastError %}
            <p class="error">{{ latestRun.lastError }}</p>
        {% endif %}

        {% if latestRun.deleteStatus %}
            <div class="so-section-header">
                <h3>{{ "Ghost asset deletion"|t('storage-optimizer') }}</h3>
            </div>

            <div class="so-metrics">
                <div class="so-metric">
                    <div class="so-metric-label">{{ "Status"|t('storage-optimizer') }}</div>
                    <div class="so-metric-value">{{ latestRun.deleteStatus }}</div>
                </div>
                <div class="so-metric">
                    <div class="so-metric-label">{{ "Attempted"|t('storage-optimizer') }}</div>
                    <div class="so-metric-value">{{ latestRun.deleteAttemptedAssets|number }}</div>
                </div>
                <div class="so-metric">
                    <div class="so-metric-label">{{ "Deleted"|t('storage-optimizer') }}</div>
                    <div class="so-metric-value">{{ latestRun.deleteDeletedAssets|number }}</div>
                </div>
                <div class="so-metric">
                    <div class="so-metric-label">{{ "Skipped"|t('storage-optimizer') }}</div>
                    <div class="so-metric-value">{{ latestRun.deleteSkippedAssets|number }}</div>
                </div>
                <div class="so-metric">
                    <div class="so-metric-label">{{ "Failed"|t('storage-optimizer') }}</div>
                    <div class="so-metric-value">{{ latestRun.deleteFailedAssets|number }}</div>
                </div>
                <div class="so-metric">
                    <div class="so-metric-label">{{ "Deleted bytes"|t('storage-optimizer') }}</div>
                    <div class="so-metric-value">{{ latestRun.deleteDeletedBytesFormatted }}</div>
                </div>
            </div>

            {% if latestRun.deleteLastError %}
                <p class="error">{{ latestRun.deleteLastError }}</p>
            {% endif %}
        {% endif %}

        <div class="so-section-header">
            <h3>{{ "Ghost asset report"|t('storage-optimizer') }}</h3>
            {% if ghostAssetReport and ghostAssetReport.total %}
                <div class="so-report-meta">
                    {{ "Showing {from}-{to} of {total}"|t('storage-optimizer', {
                        from: ghostAssetReport.from|number,
                        to: ghostAssetReport.to|number,
                        total: ghostAssetReport.total|number,
                    }) }}
                </div>
            {% endif %}
        </div>

        {% if topGhostAssets %}
            <div class="so-table-wrap">
                <table class="data fullwidth so-report-table">
                    <thead>
                        <tr>
                            <th>{{ reportUi.sortHeading(ghostAssetReport, 'assetId', 'Asset ID') }}</th>
                            <th>{{ reportUi.sortHeading(ghostAssetReport, 'filename', 'Filename') }}</th>
                            <th>{{ reportUi.sortHeading(ghostAssetReport, 'kind', 'Kind') }}</th>
                            <th>{{ reportUi.sortHeading(ghostAssetReport, 'extension', 'Ext') }}</th>
                            <th class="so-number">{{ reportUi.sortHeading(ghostAssetReport, 'size', 'Size') }}</th>
                            <th>{{ reportUi.sortHeading(ghostAssetReport, 'volume', 'Volume') }}</th>
                            <th>{{ reportUi.sortHeading(ghostAssetReport, 'dateCreated', 'Created') }}</th>
                            <th>{{ "Owner"|t('storage-optimizer') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for asset in topGhostAssets %}
                            {% set assetVolume = asset.volumeName ?: (asset.volumeId ? '#' ~ asset.volumeId : '-') %}
                            <tr>
                                <td>
                                    {% if asset.assetCpEditUrl %}
                                        <a href="{{ asset.assetCpEditUrl }}"><code>{{ asset.assetId }}</code></a>
                                    {% else %}
                                        <code>{{ asset.assetId }}</code>
                                    {% endif %}
                                </td>
                                <td class="so-filename">
                                    {% if asset.assetUrl %}
                                        <a href="{{ asset.assetUrl }}" target="_blank" rel="noopener">{{ asset.filename }}</a>
                                    {% else %}
                                        {{ asset.filename }}
                                    {% endif %}
                                </td>
                                <td>{{ asset.kind ?: '-' }}</td>
                                <td>{{ asset.extension ?: '-' }}</td>
                                <td class="so-number">{{ asset.sizeFormatted }}</td>
                                <td>{{ assetVolume }}</td>
                                <td>{{ asset.assetDateCreatedFormatted }}</td>
                                <td>
                                    {% if asset.ownerUrl %}
                                        <a href="{{ asset.ownerUrl }}">{{ asset.ownerTitle ?: '#' ~ asset.ownerId }}</a>
                                    {% elseif asset.ownerId %}
                                        <code>{{ asset.ownerId }}</code>
                                    {% else %}
                                        <span class="so-muted">-</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="so-pagination">
                <div class="so-report-meta">
                    {{ "Page {page} of {totalPages}"|t('storage-optimizer', {
                        page: ghostAssetReport.page|number,
                        totalPages: ghostAssetReport.totalPages|number,
                    }) }}
                </div>
                <div class="so-pager-buttons">
                    <a class="btn small" href="{{ ghostAssetReport.paginationUrls.first }}">{{ "First"|t('storage-optimizer') }}</a>
                    <a class="btn small" href="{{ ghostAssetReport.paginationUrls.previous }}">{{ "Previous"|t('storage-optimizer') }}</a>
                    <a class="btn small" href="{{ ghostAssetReport.paginationUrls.next }}">{{ "Next"|t('storage-optimizer') }}</a>
                    <a class="btn small" href="{{ ghostAssetReport.paginationUrls.last }}">{{ "Last"|t('storage-optimizer') }}</a>
                </div>
                <div class="so-page-size">
                    <span class="so-page-size-label">{{ "Rows"|t('storage-optimizer') }}</span>
                    {% for option in ghostAssetReport.perPageOptions %}
                        <a class="btn small{{ option.value == ghostAssetReport.perPage ? ' active' : '' }}" href="{{ option.url }}">{{ option.value }}</a>
                    {% endfor %}
                </div>
            </div>
        {% else %}
            <p>{{ "No ghost assets were captured in the latest snapshot."|t('storage-optimizer') }}</p>
        {% endif %}
    {% endif %}
</div>
