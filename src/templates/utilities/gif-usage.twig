{% import "_includes/forms" as forms %}

<div class="readable">
    <h2>{{ "GIF Usage"|t('storage-optimizer') }}</h2>
    <p>{{ "Scans are queued and processed in batches. Usage references are counted through Craft relations, so GIFs selected in normal asset fields and asset fields nested inside Matrix blocks are included."|t('storage-optimizer') }}</p>
</div>

<div class="buttons" style="margin: 24px 0;">
    <form method="post" accept-charset="UTF-8" style="display: inline-block; margin-right: 8px;">
        {{ csrfInput() }}
        {{ actionInput('storage-optimizer/insights/scan') }}
        {{ redirectInput(craft.app.request.url) }}
        {{ forms.text({
            name: 'batchSize',
            value: defaultBatchSize,
            type: 'number',
            min: 1,
            max: 5000,
            size: 5,
        }) }}
        <button type="submit" class="btn submit">{{ "Start scan"|t('storage-optimizer') }}</button>
    </form>

    {% if latestRun %}
        <form method="post" accept-charset="UTF-8" style="display: inline-block;">
            {{ csrfInput() }}
            {{ actionInput('storage-optimizer/insights/clear') }}
            {{ redirectInput(craft.app.request.url) }}
            <button type="submit" class="btn">{{ "Clear snapshots"|t('storage-optimizer') }}</button>
        </form>

        {% if latestRun.status == 'completed' and latestRun.unusedAssets > 0 and not latestRun.deleteIsActive %}
            <form method="post" accept-charset="UTF-8" style="display: inline-block; margin-left: 8px;">
                {{ csrfInput() }}
                {{ actionInput('storage-optimizer/insights/delete-unused') }}
                {{ redirectInput(craft.app.request.url) }}
                {{ hiddenInput('runId', latestRun.id) }}
                {{ forms.text({
                    name: 'batchSize',
                    value: defaultDeleteBatchSize,
                    type: 'number',
                    min: 1,
                    max: 1000,
                    size: 5,
                }) }}
                <button type="submit" class="btn submit delete" data-confirm="{{ "Queue deletion of {count} unused GIF assets from this snapshot? Assets are re-checked before deletion and moved to Craft's trash."|t('storage-optimizer', { count: latestRun.unusedAssets }) }}">{{ "Delete unused GIF assets"|t('storage-optimizer') }}</button>
            </form>
        {% endif %}
    {% endif %}
</div>

{% if not latestRun %}
    <p>{{ "No GIF usage scan has been run yet."|t('storage-optimizer') }}</p>
{% else %}
    <div class="meta read-only">
        <div class="data">
            <h5 class="heading">{{ "Status"|t('storage-optimizer') }}</h5>
            <div class="value">{{ latestRun.status }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ "GIF assets"|t('storage-optimizer') }}</h5>
            <div class="value">{{ latestRun.gifAssets|number }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ "Total size"|t('storage-optimizer') }}</h5>
            <div class="value">{{ latestRun.totalBytesFormatted }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ "Average size"|t('storage-optimizer') }}</h5>
            <div class="value">{{ latestRun.averageBytesFormatted }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ "Used assets"|t('storage-optimizer') }}</h5>
            <div class="value">{{ latestRun.usedAssets|number }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ "Unused assets"|t('storage-optimizer') }}</h5>
            <div class="value">{{ latestRun.unusedAssets|number }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ "Relation references"|t('storage-optimizer') }}</h5>
            <div class="value">{{ latestRun.relationCount|number }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ "Direct references"|t('storage-optimizer') }}</h5>
            <div class="value">{{ latestRun.directRelationCount|number }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ "Matrix references"|t('storage-optimizer') }}</h5>
            <div class="value">{{ latestRun.matrixRelationCount|number }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ "Owner references"|t('storage-optimizer') }}</h5>
            <div class="value">{{ latestRun.ownerElementCount|number }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ "Largest GIF"|t('storage-optimizer') }}</h5>
            <div class="value">
                {{ latestRun.largestBytesFormatted }}
                {% if latestRun.largestAssetId %}<span class="light">#{{ latestRun.largestAssetId }}</span>{% endif %}
            </div>
        </div>
    </div>

    {% if latestRun.lastError %}
        <p class="error">{{ latestRun.lastError }}</p>
    {% endif %}

    {% if latestRun.deleteStatus %}
        <hr>

        <h3>{{ "Unused GIF deletion"|t('storage-optimizer') }}</h3>

        <div class="meta read-only">
            <div class="data">
                <h5 class="heading">{{ "Status"|t('storage-optimizer') }}</h5>
                <div class="value">{{ latestRun.deleteStatus }}</div>
            </div>
            <div class="data">
                <h5 class="heading">{{ "Attempted"|t('storage-optimizer') }}</h5>
                <div class="value">{{ latestRun.deleteAttemptedAssets|number }}</div>
            </div>
            <div class="data">
                <h5 class="heading">{{ "Deleted"|t('storage-optimizer') }}</h5>
                <div class="value">{{ latestRun.deleteDeletedAssets|number }}</div>
            </div>
            <div class="data">
                <h5 class="heading">{{ "Skipped"|t('storage-optimizer') }}</h5>
                <div class="value">{{ latestRun.deleteSkippedAssets|number }}</div>
            </div>
            <div class="data">
                <h5 class="heading">{{ "Failed"|t('storage-optimizer') }}</h5>
                <div class="value">{{ latestRun.deleteFailedAssets|number }}</div>
            </div>
            <div class="data">
                <h5 class="heading">{{ "Deleted GIF bytes"|t('storage-optimizer') }}</h5>
                <div class="value">{{ latestRun.deleteFreedBytesFormatted }}</div>
            </div>
        </div>

        {% if latestRun.deleteLastError %}
            <p class="error">{{ latestRun.deleteLastError }}</p>
        {% endif %}
    {% endif %}

    <hr>

    <h3>{{ "Largest GIF assets"|t('storage-optimizer') }}</h3>

    {% if topAssets %}
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>{{ "Asset ID"|t('storage-optimizer') }}</th>
                    <th>{{ "Filename"|t('storage-optimizer') }}</th>
                    <th>{{ "Size"|t('storage-optimizer') }}</th>
                    <th>{{ "References"|t('storage-optimizer') }}</th>
                    <th>{{ "Direct refs"|t('storage-optimizer') }}</th>
                    <th>{{ "Matrix refs"|t('storage-optimizer') }}</th>
                    <th>{{ "Owner refs"|t('storage-optimizer') }}</th>
                    <th>{{ "Conversion"|t('storage-optimizer') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for asset in topAssets %}
                    <tr>
                        <td><code>{{ asset.assetId }}</code></td>
                        <td>{{ asset.filename }}</td>
                        <td>{{ asset.sizeFormatted }}</td>
                        <td>{{ asset.relationCount|number }}</td>
                        <td>{{ asset.directRelationCount|number }}</td>
                        <td>{{ asset.matrixRelationCount|number }}</td>
                        <td>{{ asset.ownerElementCount|number }}</td>
                        <td>{{ asset.conversionStatus ?? '-' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>{{ "No GIF assets were captured in the latest snapshot."|t('storage-optimizer') }}</p>
    {% endif %}
{% endif %}
